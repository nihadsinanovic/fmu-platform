# FMU Platform — Caddy Reverse Proxy
#
# Routes:
#   {DOMAIN}         → production API
#   {STAGING_DOMAIN}  → staging API
#
# When DOMAIN is ":80", serves plain HTTP (no TLS) — for dev/testing.
# When DOMAIN is a real domain, Caddy auto-provisions HTTPS via Let's Encrypt.

# ── Production ───────────────────────────────────────────────────────────
{$DOMAIN::80} {
	handle /api/* {
		reverse_proxy api:8000
	}

	handle /admin* {
		reverse_proxy api:8000
	}

	handle /docs* {
		reverse_proxy api:8000
	}

	handle /openapi.json {
		reverse_proxy api:8000
	}

	handle /ws/* {
		reverse_proxy api:8000
	}

	handle {
		respond "FMU Platform API (production). See /docs or /admin" 200
	}

	request_body {
		max_size 100MB
	}
}

# ── Staging (only active when STAGING_DOMAIN is set) ─────────────────────
{$STAGING_DOMAIN:} {
	handle /api/* {
		reverse_proxy api-staging:8000
	}

	handle /admin* {
		reverse_proxy api-staging:8000
	}

	handle /docs* {
		reverse_proxy api-staging:8000
	}

	handle /openapi.json {
		reverse_proxy api-staging:8000
	}

	handle /ws/* {
		reverse_proxy api-staging:8000
	}

	handle {
		respond "FMU Platform API (staging). See /docs or /admin" 200
	}

	request_body {
		max_size 100MB
	}
}
