# FMU Platform — Caddy Reverse Proxy
#
# When DOMAIN is set to a real domain (e.g. fmu.example.com), Caddy
# automatically gets an HTTPS cert from Let's Encrypt.
#
# When DOMAIN is "localhost" or empty, serves plain HTTP on port 80.

{$DOMAIN::80} {
	# API endpoints
	handle /api/* {
		reverse_proxy api:8000
	}

	# WebSocket for job progress
	handle /ws/* {
		reverse_proxy api:8000
	}

	# Frontend (when deployed — static files or proxy to frontend container)
	# For now, return a simple response
	handle {
		respond "FMU Platform API is running. See /api/docs" 200
	}

	# Upload size limit for SSP packages
	request_body {
		max_size 100MB
	}
}
