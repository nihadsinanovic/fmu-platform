# ┌──────────────────────────────────────────────────────────────────────┐
# │  FMU Platform — Environment Variables                              │
# │                                                                    │
# │  DO NOT edit this file directly. Run ./setup.sh to generate a      │
# │  .env file with auto-generated passwords.                          │
# └──────────────────────────────────────────────────────────────────────┘

# === PostgreSQL ===
POSTGRES_DB=fmu_platform
POSTGRES_USER=fmu
POSTGRES_PASSWORD=CHANGE_ME

# === Redis ===
REDIS_PASSWORD=CHANGE_ME

# === Backend ===
# Use "postgres" as host (Docker service name), not "localhost"
DATABASE_URL=postgresql+asyncpg://fmu:CHANGE_ME@postgres/fmu_platform
DATABASE_URL_SYNC=postgresql://fmu:CHANGE_ME@postgres/fmu_platform
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# === License Management ===
LICENSE_POOL_SIZE=3
AMESIM_LICENSE_SERVER=29000@your-license-server

# === Storage Paths (inside containers) ===
FMU_LIBRARY_PATH=/opt/fmu-platform/fmu-library
PROJECTS_PATH=/opt/fmu-platform/projects
TEMP_PATH=/opt/fmu-platform/temp

# === Auth ===
SECRET_KEY=CHANGE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === CORS (comma-separated or JSON array) ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
