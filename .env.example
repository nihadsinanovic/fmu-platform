# === PostgreSQL ===
POSTGRES_DB=fmu_platform
POSTGRES_USER=fmu
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# === Redis ===
REDIS_PASSWORD=CHANGE_ME_redis_password

# === Backend ===
DATABASE_URL=postgresql://fmu:CHANGE_ME_strong_password_here@postgres/fmu_platform
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379/0

# === License Management ===
LICENSE_POOL_SIZE=3
AMESIM_LICENSE_SERVER=27000@license-server-host

# === Storage Paths (inside containers) ===
FMU_LIBRARY_PATH=/opt/fmu-platform/fmu-library
PROJECTS_PATH=/opt/fmu-platform/projects
TEMP_PATH=/opt/fmu-platform/temp

# === Auth ===
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === CORS (comma-separated frontend origins) ===
CORS_ORIGINS=["https://your-domain.com"]
